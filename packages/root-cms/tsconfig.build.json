{
  "extends": "./core/tsconfig.json",
  "compilerOptions": {
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "ignoreDeprecations": "6.0",
    "noCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": ["cli/**/*.ts", "core/**/*.ts", "core/**/*.tsx", "shared/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
