{
  "extends": "./core/tsconfig.json",
  "compilerOptions": {
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "noCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "browser-client/**/*.ts",
    "cli/**/*.ts",
    "core/**/*.ts",
    "core/**/*.tsx",
    "shared/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
