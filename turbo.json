{
  "$schema": "https://v2-10-4.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:prod": {
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false
    }
  }
}
