{
  "name": "@blinkk/root-project",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Root.js is a developer-focused CMS that writes directly to Firestore.",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "main": "index.js",
  "scripts": {
    "cms:dev": "./scripts/dev_cms.sh",
    "build": "turbo run build --filter=\"@blinkk/*\"",
    "changeset": "changeset",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "version": "changeset version && pnpm install --no-frozen-lockfile",
    "release": "pnpm run build && changeset publish",
    "release:ci": "pnpm run build && changeset publish",
    "test": "pnpm run build && turbo run test",
    "test:prod": "turbo run test:prod --filter=\"@examples/blog\"",
    "cms": "pnpm --filter=\"@blinkk/root-cms\"",
    "root": "pnpm --filter=\"@blinkk/root\"",
    "root-cms": "pnpm --filter=\"@blinkk/root-cms\"",
    "// workspace aliases": "",
    "blog": "pnpm run --filter=\"@examples/blog\"",
    "starter": "pnpm run --filter=\"@examples/starter\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blinkk/rootjs.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/blinkk/rootjs/issues"
  },
  "homepage": "https://github.com/blinkk/rootjs#readme",
  "devDependencies": {
    "@blinkk/eslint-config-root": "workspace:*",
    "@changesets/cli": "2.31.0",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "turbo": "2.10.4",
    "typescript": "7.0.2"
  }
}
